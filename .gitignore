# Python / uv
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/

# SLURM / experiment logs: keep the directory, ignore its contents
scripts/logs/*
!scripts/logs/.gitkeep
slurm-*.out
slurm-*.err
smoketest_*.out
smoketest_*.err

# Reproduction pipeline:
#   - logs are noisy SLURM stdout/stderr: ignore
#   - fresh_runs/ CSVs are small reproduction artifacts: track them
#   - figures/ PNGs and PDFs are verified reproduction outputs: track them
Reproduction/logs/*
!Reproduction/logs/.gitkeep

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# Ad-hoc scratch
*.log

# Personal task tracking (user workflow files, not part of the fork)
tasks/
